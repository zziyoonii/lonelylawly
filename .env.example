# Gemini API 키 (https://aistudio.google.com/app/apikey 에서 발급)
GEMINI_API_KEY=여기에_발급받은_키_입력

# 선택: Claude Haiku API 키 (https://console.anthropic.com 에서 발급, 유료)
# ANTHROPIC_API_KEY=

# 선택: Google Analytics 4 (예: G-XXXXXXXXXX)
# GA_MEASUREMENT_ID=

# 선택: Google AdSense (예: ca-pub-XXXXXXXXXXXXXXXX)
# ADSENSE_CLIENT_ID=

# 선택: SEO canonical URL (배포 도메인, 예: https://lawform.example.com)
# CANONICAL_URL=

# 선택: 국가법령정보 공동활용 API OC 인증값 (open.law.go.kr 발급)
# LAW_API_OC=bluesky910816

# 선택: 토스 앱 바로 송금 링크 (모바일, 미설정 시 supertoss:// 자동 사용)
# TOSS_TRANSFER_LINK=
